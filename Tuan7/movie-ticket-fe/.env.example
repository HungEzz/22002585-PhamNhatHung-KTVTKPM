# Bản build / demo LAN: URL một cổng duy nhất (Gateway hoặc service có route tổng hợp)
# Ví dụ: http://192.168.1.50:8080
VITE_API_BASE_URL=

# Dev: để trống → app gọi /api/... và Vite proxy (vite.config.ts) chuyển tới Gateway.
# Windows PowerShell tạm thời:
#   $env:VITE_DEV_PROXY_TARGET="http://192.168.x.x:8080"; npm run dev
