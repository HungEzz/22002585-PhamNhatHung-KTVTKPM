# Copy thành .env. Vite chỉ đọc biến VITE_*
#
# Khi gặp Network Error / CORS khi chạy npm run dev: bật proxy
# VITE_USE_PROXY=true
# (trình duyệt gọi localhost:5173/api/... → Vite chuyển tiếp tới các URL bên dưới)
# Demo LAN không proxy: VITE_USE_PROXY=false và URL đầy đủ http://IP:port

VITE_USE_PROXY=false

# User local: http://localhost:8081
VITE_USER_SERVICE_URL=http://192.168.1.10:8081
VITE_FOOD_SERVICE_URL=http://192.168.1.11:8082
VITE_ORDER_SERVICE_URL=http://192.168.1.12:8083
# Payment service (nhóm 5) — mặc định port 8084, ví dụ IP máy bạn bạn
VITE_PAYMENT_SERVICE_URL=http://192.168.1.13:8084
